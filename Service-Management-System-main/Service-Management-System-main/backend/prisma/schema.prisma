generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// AUTH (ADMIN ONLY)
//////////////////////////////////////////////////////

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resetToken        String?
  resetTokenExpiry  DateTime?
}

enum Role {
  ADMIN
  CUSTOMER
  SERVICE_ADVISOR
  TECHNICIAN
  SUPPLY_CHAIN
  SALES
}

//////////////////////////////////////////////////////
// TECHNICIAN PROFILES (NO LOGIN, SHARED AUTH)
//////////////////////////////////////////////////////

model TechnicianProfile {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  serviceBookings ServiceBooking[]
}



//////////////////////////////////////////////////////
// CUSTOMER & VEHICLE
//////////////////////////////////////////////////////
model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  mobileNumber String   @unique
  email        String?  @unique 
  address      String?
  gstNumber    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  passwordHash String?

  vehicles Vehicle[]
  jobCards JobCard[]
  serviceBookings ServiceBooking[]
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Vehicle {
  id               Int      @id @default(autoincrement())
  customerId       Int
  vinNumber        String @unique
  model            String
  registrationNumber String?
  batteryNumber    String?
  motorNumber      String?
  chargerNumber    String?
  warrantyStatus   String?
  imageUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  jobCards JobCard[]   
}



//////////////////////////////////////////////////////
// JOB CARD (CORE)
//////////////////////////////////////////////////////

model JobCard {
  id                 Int        @id @default(autoincrement())
  jobCardNumber      String     @unique
  customerId         Int
  vehicleId          Int
  serviceInDatetime  DateTime
  serviceType        ServiceType
  status             JobStatus  @default(OPEN)
  odometer           Int?
  batteryVoltage     Float?
  remarks            String?
  createdAt          DateTime   @default(now())
  closedAt           DateTime?
  updatedAt          DateTime   @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])

  complaints   ServiceComplaint[]
  inspections  VehicleInspection[]
  parts        PartsReplacement[]
  media        JobCardMedia[]
  workLogs     WorkLog[]

  // ==============
  serviceBooking ServiceBooking?

  @@index([customerId])
  @@index([vehicleId])
}


//////////////////////////////////////////////////////
// WORK TRACKING (KEY FEATURE)
//////////////////////////////////////////////////////

model WorkLog {
  id             Int        @id @default(autoincrement())
  jobCardId      Int
  taskName       String
  description    String?    
  technicianName String
  status         WorkStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([jobCardId])
}

//////////////////////////////////////////////////////
// INSPECTION
//////////////////////////////////////////////////////

model VehicleInspection {
  id            Int                 @id @default(autoincrement())
  jobCardId     Int
  componentName String
  condition     InspectionCondition
  createdAt     DateTime            @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([jobCardId])
}

//////////////////////////////////////////////////////
// COMPLAINTS
//////////////////////////////////////////////////////

model ServiceComplaint {
  id          Int               @id @default(autoincrement())
  jobCardId   Int
  category    ComplaintCategory
  workType    WorkType
  description String
  createdAt   DateTime          @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([jobCardId])
   viewedByAdminAt DateTime?
}

//////////////////////////////////////////////////////
// PARTS
//////////////////////////////////////////////////////

model PartsReplacement {
  id                 Int        @id @default(autoincrement())
  jobCardId          Int
  partName           String
  partNumber         String?
  action             PartAction
  warrantyApplicable Boolean
  createdAt          DateTime   @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([jobCardId])
}

//////////////////////////////////////////////////////
// MEDIA
//////////////////////////////////////////////////////

model JobCardMedia {
  id         Int            @id @default(autoincrement())
  jobCardId  Int
  fileUrl    String
  fileType   MediaType
  context    MediaContext   @default(GENERAL)
  uploadedAt DateTime       @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([jobCardId])
}

////////////////////////////////////////////////////
enum BookingStatus {
  NEW
  CLAIMED
  IN_PROGRESS
  COMPLETED
}

model ServiceBooking {
  id            Int      @id @default(autoincrement())
  customerId    Int
  vehiclePart   String
  serviceType   String
  preferredDate DateTime
  timeSlot      String
  notes         String?
  

  status        BookingStatus @default(NEW)
  createdAt     DateTime @default(now())

  viewedByAdminAt DateTime?

  jobCardId Int?     @unique
  jobCard   JobCard? @relation(fields: [jobCardId], references: [id])

  customer Customer @relation(fields: [customerId], references: [id])

  claimedByProfileId Int?
  claimedByProfile   TechnicianProfile? @relation(fields: [claimedByProfileId], references: [id])

  media ServiceBookingMedia[]   

  @@unique([preferredDate, timeSlot])
}

//////////////////////////////////////////////////////////
model ServiceBookingMedia {
  id               Int      @id @default(autoincrement())
  serviceBookingId Int
  fileUrl          String
  fileType         String
  uploadedBy       Int
  createdAt        DateTime @default(now())

  serviceBooking ServiceBooking @relation(fields: [serviceBookingId], references: [id], onDelete: Cascade)
}




/////////////////////////////////////////////////////////////
//TestRide
//////////////////////////////////////////////////////////

model TestRide {
  id        Int      @id @default(autoincrement())
  bikeName  String
  location  String
  date      DateTime
  timeSlot  String
  fullName  String
  phone     String
  email     String?

  address   String?   
  feedback  String?  
  rating    Int? 

  status    String    @default("CONFIRMED")
  isViewed  Boolean   @default(false)
  createdAt DateTime  @default(now())
}


//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum JobStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum WorkType {
  PAID
  COMPLAINT
  WARRANTY
}

enum ComplaintCategory {
  Battery
  Brakes
  Suspension
  Charger
  Electronics
  Display
  Power
  Others
}

enum InspectionCondition {
  OK
  NOT_OK
  DAMAGE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PartAction {
  NEW
  REPLACE
  REFURBISHED
}

enum WorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum MediaContext {
  INSPECTION
  COMPLAINT
  PART_REPLACEMENT
  GENERAL
}
enum ServiceType {
  GENERAL
  COMPLAINT
  BATTERY
  CHARGER
  PAID_SERVICE_REPAIRABLE
  PAID_SERVICE_WARRANTY
  SPARES_DISPATCH
}
